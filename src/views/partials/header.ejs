    <% const messages = flash(); %>

<% if (Object.values(messages).some(messageList => messageList.length > 0)) { %>
    <div class="flash-messages" role="status" aria-live="polite">
        <% Object.keys(messages).forEach(type => { %>
            <% messages[type].forEach(msg => { %>
                <div class="alert <%= type %>">
                    <%= msg %>
                </div>
            <% }); %>
        <% }); %>
    </div>
<% } %>
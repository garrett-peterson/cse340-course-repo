<%- include('partials/header') %>

<main>
    <h1><%= title %></h1>

    <h2><%= projectDetails.project_title %></h2>

    <p>Description: <%= projectDetails.description %></p>

    <p>Project Date: <%= projectDetails.project_date %></p>

    <p>Project Location: <%= projectDetails.project_location %></p>

    <p>
        Partner Organization:
        <a href="/organization/<%= projectDetails.organization_id %>">
            <%= projectDetails.organization_name %>
        </a>
    </p>

    <h3>Categories</h3>

    <ul>
        <% categories.forEach(category => { %>
            <li>
                <a href="/category/<%= category.category_id %>">
                    <%= category.category_name %>
                </a>
            </li>
        <% }); %>
    </ul>
    <% if (isLoggedIn) { %>
        <% if (isVolunteered) { %>
            <form action="/project/<%= projectDetails.project_id %>/unvolunteer" method="POST">
                <button type="submit">Unvolunteer for Project</button>
            </form>
        <% } else { %>
            <form action="/project/<%= projectDetails.project_id %>/volunteer" method="POST">
                <button type="submit">Volunteer for Project</button>
            </form>
        <% } %>
    <% } %>
    <% if (user && user.role_name === 'admin') { %>
        <a href="/assign-categories/<%= projectDetails.project_id %>">Edit Categories</a>
        <a href="/edit-project/<%= projectDetails.project_id %>">Edit Project</a>
    <% } %>
</main>

<%- include('partials/footer') %>
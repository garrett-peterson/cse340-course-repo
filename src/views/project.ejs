<%- include('partials/header') %>

<main>
    <h1><%= title %></h1>

    <h2><%= projectDetails.project_title %></h2>

    <p>Description: <%= projectDetails.description %></p>

    <p>Project Date: <%= projectDetails.project_date %></p>

    <p>Project Location: <%= projectDetails.project_location %></p>

    <p>
        Partner Organization:
        <a href="/organization/<%= projectDetails.organization_id %>">
            <%= projectDetails.organization_name %>
        </a>
    </p>

    <h3>Categories</h3>

    <ul>
        <% categories.forEach(category => { %>
            <li>
                <a href="/category/<%= category.category_id %>">
                    <%= category.category_name %>
                </a>
            </li>
        <% }); %>
    </ul>
</main>

<%- include('partials/footer') %>